@{
    ViewData["Title"] = "Quên mật khẩu";
}
<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow border-0 rounded-4 p-4">
                <div class="text-center mb-4">
                    <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-inline-flex p-3 mb-3">
                        <i class="bi bi-shield-lock fs-1"></i>
                    </div>
                    <h4 class="fw-bold">Khôi phục mật khẩu</h4>
                    <p class="text-muted small">Vui lòng nhập Email hoặc Số điện thoại để nhận mã xác thực (OTP).</p>
                </div>

                <form asp-controller="User" asp-action="ResetPassword" method="get">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Email / Số điện thoại</label>
                        <div class="input-group">
                            <input type="text" class="form-control" placeholder="Nhập email hoặc SĐT..." required>
                            <button class="btn btn-outline-primary" type="button" onclick="alert('Mã OTP 6 số đã được gửi!')">Gửi mã</button>
                        </div>
                    </div>
                    <div class="mb-4">
                        <label class="form-label fw-bold">Mã xác thực OTP</label>
                        <input type="text" class="form-control text-center fw-bold fs-5" placeholder="- - - - - -" maxlength="6" required>
                    </div>
                    <button type="submit" class="btn btn-primary w-100 fw-bold py-2">Xác nhận danh tính</button>
                    <div class="text-center mt-3">
                        <a asp-action="Login" class="text-decoration-none text-muted"><i class="bi bi-arrow-left me-1"></i>Quay lại đăng nhập</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>