@{
    ViewData["Title"] = "Quên mật khẩu";
}
<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow border-0 rounded-4 p-4">
                <div class="text-center mb-4">
                    <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-inline-flex p-3 mb-3">
                        <i class="bi bi-shield-lock fs-1"></i>
                    </div>
                    <h4 class="fw-bold">Khôi phục mật khẩu</h4>
                    <p class="text-muted small">Vui lòng nhập Email để nhận mã xác thực (OTP).</p>

                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger py-2 small fw-bold">@TempData["Error"]</div>
                    }
                </div>

                <form asp-controller="User" asp-action="VerifyOtp" method="post">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Email của bạn</label>
                        <div class="input-group">
                            <input type="email" class="form-control" id="emailInput" placeholder="Nhập email..." required>
                            <button class="btn btn-outline-primary fw-bold" type="button" id="btnSendOtp">Gửi mã</button>
                        </div>
                        <small class="text-success fw-bold mt-1 d-none" id="msgSuccess"></small>
                    </div>
                    <div class="mb-4">
                        <label class="form-label fw-bold">Mã xác thực OTP</label>
                        <input type="text" name="otpCode" class="form-control text-center fw-bold fs-5" placeholder="- - - - - -" maxlength="6" required>
                    </div>
                    <button type="submit" class="btn btn-primary w-100 fw-bold py-2">Xác nhận danh tính</button>
                    <div class="text-center mt-3">
                        <a asp-action="Login" class="text-decoration-none text-muted"><i class="bi bi-arrow-left me-1"></i>Quay lại đăng nhập</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('btnSendOtp').addEventListener('click', function () {
            var email = document.getElementById('emailInput').value;
            if (!email) {
                alert('Anh phải nhập email trước rồi mới gửi mã được chứ!');
                return;
            }

            var btn = this;
            var msg = document.getElementById('msgSuccess');

            // Đổi trạng thái nút bấm để tránh bấm nhiều lần
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> Đang gửi...';

            // Gọi xuống hàm SendOtp trong UserController
            fetch('/User/SendOtp', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                },
                body: 'email=' + encodeURIComponent(email)
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    msg.innerText = data.message;
                    msg.classList.remove('d-none');
                    btn.innerHTML = 'Đã gửi';
                } else {
                    alert('Có lỗi xảy ra, anh kiểm tra lại xem.');
                    btn.disabled = false;
                    btn.innerHTML = 'Gửi mã';
                }
            })
            .catch(error => {
                console.error('Error:', error);
                btn.disabled = false;
                btn.innerHTML = 'Gửi lại';
            });
        });
    </script>
}