@model WebDauGiaDomain.Entities.User
@{
    ViewData["Title"] = "Thiết lập tài khoản";
}

<div class="container my-5">
    <h3 class="fw-bold mb-4 border-bottom pb-2"><i class="bi bi-gear-fill me-2 text-secondary"></i>Thiết lập tài khoản</h3>

    <div class="row g-4">
        <div class="col-md-6">
            <div class="card shadow-sm border-0 rounded-4 p-4 h-100">
                <h5 class="fw-bold mb-3">Ảnh đại diện</h5>
                <div class="d-flex align-items-center mb-3">
                    <img src="@(Model.AvatarUrl ?? "/picture/default-avatar.png")" class="rounded-circle border shadow-sm me-3" width="80" height="80" style="object-fit: cover;">
                    <form asp-action="UploadAvatar" method="post" enctype="multipart/form-data" class="flex-grow-1">
                        <input type="file" name="avatarFile" class="form-control form-control-sm mb-2" accept="image/*" required>
                        <button type="submit" class="btn btn-sm btn-primary px-4">Tải ảnh lên</button>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card shadow-sm border-0 rounded-4 p-4 h-100">
                <h5 class="fw-bold mb-3">Bảo mật & Hoạt động</h5>
                <div class="d-grid gap-3">
                    <a asp-action="ForgotPassword" class="btn btn-outline-secondary text-start fw-bold">
                        <i class="bi bi-shield-lock me-2"></i> Đổi mật khẩu
                    </a>
                    <a asp-action="ViewHistory" class="btn btn-outline-secondary text-start fw-bold">
                        <i class="bi bi-clock-history me-2"></i> Lịch sử sản phẩm đã xem
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-12">
            <div class="card shadow-sm border-0 rounded-4 p-4">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h5 class="fw-bold mb-1">Giao diện hệ thống</h5>
                        <p class="text-muted small mb-0">Chuyển đổi giao diện sang nền tối để bảo vệ mắt.</p>
                    </div>
                    <div class="d-flex align-items-center">
                        <div class="form-check form-switch me-3 fs-5">
                            <input class="form-check-input" type="checkbox" id="themePageCheck">
                        </div>
                        <button class="btn btn-dark fw-bold" id="applyThemeBtn">Áp dụng</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const pageThemeCheck = document.getElementById('themePageCheck');
            const applyBtn = document.getElementById('applyThemeBtn');
            const htmlElement = document.documentElement;

            // Khởi tạo trạng thái nút gạt
            const currentTheme = localStorage.getItem('theme') || 'light';
            pageThemeCheck.checked = (currentTheme === 'dark');

            applyBtn.addEventListener('click', function () {
                const newTheme = pageThemeCheck.checked ? 'dark' : 'light';
                htmlElement.setAttribute('data-bs-theme', newTheme);
                localStorage.setItem('theme', newTheme);

                applyBtn.innerHTML = '<span class="spinner-border spinner-border-sm"></span>...';
                setTimeout(() => {
                    applyBtn.innerHTML = 'Áp dụng';
                    alert('Đã cập nhật giao diện!');
                }, 400);
            });
        });
    </script>
}