@model IEnumerable<WebDauGiaDomain.Entities.Product>
@{
    ViewData["Title"] = "Đấu giá của tôi";
}

<div class="container my-5">
    <h2 class="fw-bold text-primary mb-4">Quản lý giao dịch đấu giá</h2>
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
        <h3 class="fw-bold text-primary mb-0"><i class="bi bi-hammer me-2"></i>Đấu giá của tôi</h3>
        <a asp-controller="User" asp-action="CreateAuction" class="btn btn-success fw-bold px-4 rounded-pill shadow-sm">
            <i class="bi bi-plus-circle-fill me-2"></i>Tạo phiên đấu giá
        </a>
    </div>
    <div class="card shadow-sm border-0 mb-4 bg-light">
        <div class="card-body d-flex justify-content-between align-items-center">
            <h5 class="mb-0 fw-bold text-dark">Bộ lọc hiển thị:</h5>
            <div class="w-50">
                <select class="form-select border-primary text-primary fw-bold py-2 fs-5">
                    <option value="all" selected>Tất cả (Tổng)</option>
                    <option value="upcoming">Sắp mở</option>
                    <option value="ongoing">Đang diễn ra</option>
                    <option value="ended-bought">Đã kết thúc (Lịch sử Mua)</option>
                    <option value="ended-sold">Đã kết thúc (Lịch sử Bán)</option>
                </select>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-primary text-center">
                        <tr>
                            <th>Mã Phiên</th>
                            <th>Tên sản phẩm</th>
                            <th>Vai trò của bạn</th>
                            <th>Trạng thái</th>
                            <th>Giá hiện hành</th>
                            <th>Hành động</th>
                        </tr>
                    </thead>
                    <tbody class="text-center">
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="6" class="text-center py-5 text-muted">
                                    <i class="bi bi-box-seam fs-1 d-block mb-2"></i>
                                    Anh chưa tạo phiên đấu giá nào.
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var item in Model)
                            {
                                // Xử lý logic hiển thị
                                bool isEnded = item.AuctionEndTime <= DateTime.Now || item.IsClosed;
                                decimal displayPrice = item.CurrentPrice > 0 ? item.CurrentPrice : item.StartPrice;

                                <tr>
                                    <td class="fw-bold text-muted">AUC-@item.Id.ToString("000")</td>
                                    <td class="text-start fw-bold">@item.Name</td>
                                    <td><span class="badge bg-dark">Người Bán</span></td>
                                    <td>
                                        @if (isEnded)
                                        {
                                            <span class="badge bg-danger">Đã kết thúc</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success">Đang diễn ra</span>
                                        }
                                    </td>
                                    <td class="text-danger fw-bold">@displayPrice.ToString("N0") đ</td>
                                    <td>
                                        <a asp-controller="Home" asp-action="Detail" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary fw-bold">
                                            Vào xem
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>