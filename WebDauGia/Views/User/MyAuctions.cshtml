@{
    ViewData["Title"] = "Đấu giá của tôi";
}

<div class="container my-5">
    <h2 class="fw-bold text-primary mb-4">Quản lý giao dịch đấu giá</h2>
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
        <h3 class="fw-bold text-primary mb-0"><i class="bi bi-hammer me-2"></i>Đấu giá của tôi</h3>
        <a asp-controller="User" asp-action="CreateAuction" class="btn btn-success fw-bold px-4 rounded-pill shadow-sm">
            <i class="bi bi-plus-circle-fill me-2"></i>Tạo phiên đấu giá
        </a>
    </div>
    <div class="card shadow-sm border-0 mb-4 bg-light">
        <div class="card-body d-flex justify-content-between align-items-center">
            <h5 class="mb-0 fw-bold text-dark">Bộ lọc hiển thị:</h5>
            <div class="w-50">
                <select class="form-select border-primary text-primary fw-bold py-2 fs-5">
                    <option value="all" selected>Tất cả (Tổng)</option>
                    <option value="upcoming">Sắp mở</option>
                    <option value="ongoing">Đang diễn ra</option>
                    <option value="ended-bought">Đã kết thúc (Lịch sử Mua)</option>
                    <option value="ended-sold">Đã kết thúc (Lịch sử Bán)</option>
                </select>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-primary text-center">
                        <tr>
                            <th>Mã Phiên</th>
                            <th>Tên sản phẩm</th>
                            <th>Vai trò của bạn</th>
                            <th>Trạng thái</th>
                            <th>Giá hiện tại / Chốt</th>
                            <th>Hành động</th>
                        </tr>
                    </thead>
                    <tbody class="text-center">
                        <tr>
                            <td class="fw-bold text-muted">AUC-001</td>
                            <td class="text-start fw-bold">Mô hình Đặc biệt Uma Musume</td>
                            <td><span class="badge bg-secondary">Người Mua</span></td>
                            <td><span class="badge bg-success">Đang diễn ra</span></td>
                            <td class="text-danger fw-bold">2.500.000 đ</td>
                            <td><button class="btn btn-sm btn-outline-primary fw-bold">Vào xem</button></td>
                        </tr>
                        <tr>
                            <td class="fw-bold text-muted">AUC-002</td>
                            <td class="text-start fw-bold">Đồng hồ Thụy Sỹ Cổ</td>
                            <td><span class="badge bg-dark">Người Bán</span></td>
                            <td><span class="badge bg-warning text-dark">Sắp mở</span></td>
                            <td class="text-muted">1.000.000 đ (Khởi điểm)</td>
                            <td><button class="btn btn-sm btn-outline-secondary">Sửa thông tin</button></td>
                        </tr>
                        <tr>
                            <td class="fw-bold text-muted">AUC-003</td>
                            <td class="text-start fw-bold">Bóng chữ ký U23 Việt Nam</td>
                            <td><span class="badge bg-secondary">Người Mua</span></td>
                            <td><span class="badge bg-danger">Đã kết thúc</span></td>
                            <td class="text-danger fw-bold">15.000.000 đ</td>
                            <td><button class="btn btn-sm btn-success fw-bold">Thanh toán ngay</button></td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>