@{
    ViewData["Title"] = "Tạo phiên đấu giá";
}

<div class="container my-5">
    <div class="d-flex align-items-center mb-4 pb-2 border-bottom">
        <a asp-action="MyAuctions" class="btn btn-sm btn-outline-secondary me-3"><i class="bi bi-arrow-left"></i> Trở lại</a>
        <h3 class="fw-bold text-primary mb-0">Tạo Phiên Đấu Giá Mới</h3>
    </div>

    <form asp-controller="User" asp-action="CreateAuction" method="post" enctype="multipart/form-data">
        <div class="row g-5">
            <div class="col-md-5">
                <input type="file" name="ImageFile" class="form-control w-75" accept="image/*" required>
            </div>

            <div class="col-md-7">
                <div class="mb-3">
                    <label class="form-label fw-bold">Tên sản phẩm</label>
                    <input type="text" name="ProductName" class="form-control form-control-lg" placeholder="Ví dụ: Mô hình NIKKE Red Hood 1/7..." required>
                </div>

                <div class="row mb-3">
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Phân loại danh mục</label>
                        <select name="CategoryId" class="form-select form-select-lg">
                            <option value="1">Đồ điện tử & Công nghệ</option>
                            <option value="2">Mô hình & Thẻ bài Game</option>
                            <option value="3">Phương tiện đi lại</option>
                            <option value="4">Trang sức & Đồng hồ</option>
                            <option value="5">Kỷ vật thể thao</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Giá khởi điểm (VNĐ)</label>
                        <input type="number" name="StartPrice" class="form-control form-control-lg text-danger fw-bold" placeholder="50000" min="0" required>
                    </div>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-bold">Thông tin chi tiết</label>
                    <textarea name="Description" class="form-control" rows="5" placeholder="Mô tả tình trạng, xuất xứ, năm sản xuất, các tính năng đặc biệt của sản phẩm..." required></textarea>
                </div>

                <button type="submit" class="btn btn-primary btn-lg w-100 fw-bold rounded-pill shadow-sm py-3">
                    <i class="bi bi-play-circle-fill me-2"></i>BẮT ĐẦU ĐẤU GIÁ
                </button>
            </div>
        </div>
    </form>
</div>