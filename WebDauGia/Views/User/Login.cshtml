@{
    ViewData["Title"] = "Đăng nhập";
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow-sm border-0 rounded-4 p-4">
                <div class="text-center mb-4">
                    <h3 class="fw-bold text-primary mb-2">Đăng nhập</h3>
                    <p class="text-muted small">Chào mừng bạn quay lại với hệ thống AuctionHub</p>
                </div>

                <form asp-controller="User" asp-action="Login" method="post">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Tên đăng nhập / Email</label>
                        <input type="text" class="form-control" placeholder="Nhập tài khoản của bạn..." required>
                    </div>

                    <div class="mb-3">
                        <div class="d-flex justify-content-between align-items-center">
                            <label class="form-label fw-bold mb-0">Mật khẩu</label>
                            <a asp-controller="User" asp-action="ForgotPassword" class="text-decoration-none small text-primary fw-bold">Quên mật khẩu?</a>
                        </div>
                        <input type="password" class="form-control mt-2" placeholder="Nhập mật khẩu..." required>
                    </div>

                    <div class="mb-4 form-check">
                        <input type="checkbox" class="form-check-input" id="rememberMe">
                        <label class="form-check-label text-muted select-none" for="rememberMe">Ghi nhớ đăng nhập</label>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 fw-bold py-2 mb-3">Đăng nhập</button>

                    <div class="text-center mt-2 border-top pt-3">
                        <span class="text-muted">Chưa có tài khoản? </span>
                        <a asp-controller="User" asp-action="Register" class="text-decoration-none fw-bold">Đăng ký ngay</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>