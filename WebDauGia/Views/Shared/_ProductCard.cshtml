@model WebDauGiaDomain.Entities.Product

<div class="col">
    <div class="card h-100 shadow-sm border-0 rounded-4 overflow-hidden position-relative product-card" data-product-id="@Model.Id" data-end-time="@Model.AuctionEndTime.ToString("yyyy-MM-ddTHH:mm:ss")">
        <a asp-controller="Home" asp-action="Detail" asp-route-id="@Model.Id" class="d-block position-relative">
            <img src="@Model.ImageUrl" class="card-img-top" style="height: 200px; object-fit: cover;">
            <div class="position-absolute top-0 end-0 m-2 badge bg-danger countdown-timer"
                 data-endtime="@Model.AuctionEndTime.ToString("yyyy-MM-ddTHH:mm:ss")">
                Đang tải...
            </div>
        </a>

        <div class="card-body p-3">
            <h6 class="fw-bold text-truncate mb-1">@Model.Name</h6>
            <p class="text-danger fw-bold mb-3">@Model.StartPrice.ToString("N0") đ</p>

            <div class="d-flex align-items-center justify-content-between">
                <a asp-controller="Home" asp-action="Detail" asp-route-id="@Model.Id" class="btn btn-outline-primary btn-sm rounded-pill px-3">
                    Tham gia đấu giá
                </a>
                <i class="bi bi-heart fs-5 text-secondary favorite-btn" style="cursor: pointer;" title="Thêm vào yêu thích"></i>
            </div>
        </div>
    </div>
</div>