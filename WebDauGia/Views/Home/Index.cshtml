@{
    ViewData["Title"] = "Trang chủ";
}

<div class="container mt-4">
    <div id="heroCarousel" class="carousel slide mb-5" data-bs-ride="carousel">
        <div class="carousel-indicators">
            <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="0" class="active" aria-current="true" aria-label="Slide 1"></button>
            <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="1" aria-label="Slide 2"></button>
            <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="2" aria-label="Slide 3"></button>
        </div>
        <div class="carousel-inner rounded-4 shadow-sm">
            <div class="carousel-item active">
                <a asp-controller="Home" asp-action="Detail" class="d-block"><img src="https://via.placeholder.com/1200x400/0d6efd/ffffff?text=Sieu+Pham+Dau+Gia+Cuoi+Tuan" class="d-block w-100" alt="Banner 1" style="object-fit: cover; height: 400px>;"></a>
                <div class="carousel-caption d-none d-md-block bg-dark bg-opacity-50 rounded-3 p-3">
                    <h3 class="fw-bold">🔥 Tuần lễ Siêu phẩm</h3>
                    <p class="fs-5">Cơ hội sở hữu những món đồ độc lạ với giá khởi điểm từ 0 đồng.</p>
                    <button class="btn btn-warning fw-bold px-4">Tham gia ngay</button>
                </div>
            </div>
            <div class="carousel-item">
                <a asp-controller="Home" asp-action="Detail" class="d-block"><img src="https://via.placeholder.com/1200x400/198754/ffffff?text=Đong+Ho+Thuy+Sy+Chinh+Hang" class="d-block w-100" alt="Banner 2" style="object-fit: cover; height: 400px;"></a>
                <div class="carousel-caption d-none d-md-block bg-dark bg-opacity-50 rounded-3 p-3">
                    <h3 class="fw-bold">⌚ Bộ sưu tập Đồng hồ Thụy Sỹ</h3>
                    <p class="fs-5">Cam kết chính hãng. Đấu giá minh bạch.</p>
                </div>
            </div>
            <div class="carousel-item">
                <a asp-controller="Home" asp-action="Detail" class="d-block"><img src="https://via.placeholder.com/1200x400/dc3545/ffffff?text=Thanh+Ly+Do+Cong+Nghe" class="d-block w-100" alt="Banner 3" style="object-fit: cover; height: 400px;"></a>
                <div class="carousel-caption d-none d-md-block bg-dark bg-opacity-50 rounded-3 p-3">
                    <h3 class="fw-bold">💻 Săn đồ Công nghệ giá hời</h3>
                    <p class="fs-5">Laptop, điện thoại, linh kiện máy tính giảm giá sập sàn.</p>
                </div>
            </div>
        </div>
        <button class="carousel-control-prev" type="button" data-bs-target="#heroCarousel" data-bs-slide="prev">
            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Trước</span>
        </button>
        <button class="carousel-control-next" type="button" data-bs-target="#heroCarousel" data-bs-slide="next">
            <span class="carousel-control-next-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Sau</span>
        </button>
    </div>
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-bold text-uppercase border-start border-primary border-4 ps-2">🔥 Đang đấu giá sôi nổi</h4>
        <a href="#" class="text-decoration-none text-primary fw-bold">Xem tất cả ❯</a>
    </div>

    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-4 g-4">
        
        <div class="col">
            <div class="card h-100 shadow-sm border-0 rounded-3">
                <div class="position-relative">
                    <a asp-controller="Home" asp-action="Detail" class="d-block"><img src="https://via.placeholder.com/300x200?text=Uma+Musume+Figure" class="card-img-top rounded-top" alt="Sản phẩm" style="object-fit: cover; height: 220px;"></a>
                    <span class="badge bg-danger position-absolute top-0 end-0 m-2">Sắp kết thúc</span>
                </div>
                <div class="card-body d-flex flex-column">
                    <h6 class="card-title fw-bold text-truncate" title="Mô hình nhân vật Đặc biệt Uma Musume Pretty Derby">Mô hình Đặc biệt Uma Musume Pretty Derby</h6>
                    <p class="text-danger fw-bold mb-1 fs-5">2.500.000 đ</p>
                    <p class="text-muted small mb-3">
                        ⏳ Còn lại: <span class="fw-bold text-dark countdown-timer" data-endtime="@DateTime.Now.AddHours(2).AddMinutes(15).ToString("yyyy-MM-ddTHH:mm:ss")">Đang tải...</span>
                    </p>
<a asp-controller="Home" asp-action="Detail" class="btn btn-outline-primary w-100 mt-auto fw-bold">Ra giá ngay</a>                </div>
            </div>
        </div>

        <div class="col">
            <div class="card h-100 shadow-sm border-0 rounded-3">
                <div class="position-relative">
                    <a asp-controller="Home" asp-action="Detail" class="d-block"><img src="https://via.placeholder.com/300x200?text=NIKKE+Merch" class="card-img-top rounded-top" alt="Sản phẩm" style="object-fit: cover; height: 220px;"></a>
                </div>
                <div class="card-body d-flex flex-column">
                    <h6 class="card-title fw-bold text-truncate" title="Bộ sưu tập Thẻ bài Goddess of Victory: NIKKE">Bộ sưu tập Thẻ bài Goddess of Victory: NIKKE</h6>
                    <p class="text-danger fw-bold mb-1 fs-5">850.000 đ</p>
                    <p class="text-muted small mb-3">
                        ⏳ Còn lại: <span class="fw-bold text-dark countdown-timer" data-endtime="@DateTime.Now.AddHours(4).AddMinutes(30).ToString("yyyy-MM-ddTHH:mm:ss")">Đang tải...</span>
                    </p>
                    <a asp-controller="Home" asp-action="Detail" class="btn btn-outline-primary w-100 mt-auto fw-bold">Ra giá ngay</a>
                </div>
            </div>
        </div>

        <div class="col">
            <div class="card h-100 shadow-sm border-0 rounded-3">
                <div class="position-relative">
                    <a asp-controller="Home" asp-action="Detail" class="d-block"><img src="https://via.placeholder.com/300x200?text=U23+Thuong+Chau" class="card-img-top rounded-top" alt="Sản phẩm" style="object-fit: cover; height: 220px;"></a>
                    <span class="badge bg-warning text-dark position-absolute top-0 start-0 m-2">Hiếm</span>
                </div>
                <div class="card-body d-flex flex-column">
                    <h6 class="card-title fw-bold text-truncate" title="Bóng có chữ ký đội tuyển U23 Việt Nam (Thường Châu 2018)">Bóng chữ ký U23 Việt Nam (Thường Châu 2018)</h6>
                    <p class="text-danger fw-bold mb-1 fs-5">15.000.000 đ</p>
                    <p class="text-muted small mb-3">
                        ⏳ Còn lại: <span class="fw-bold text-dark countdown-timer" data-endtime="@DateTime.Now.AddDays(1).ToString("yyyy-MM-ddTHH:mm:ss")">Đang tải...</span>
                    </p>
                    <a asp-controller="Home" asp-action="Detail" class="btn btn-outline-primary w-100 mt-auto fw-bold">Ra giá ngay</a>
                </div>
            </div>
        </div>

        <div class="col">
            <div class="card h-100 shadow-sm border-0 rounded-3">
                <div class="position-relative">
                    <a asp-controller="Home" asp-action="Detail" class="d-block"><img src="https://via.placeholder.com/300x200?text=SweetDream+Voucher" class="card-img-top rounded-top" alt="Sản phẩm" style="object-fit: cover; height: 220px;"></a>
                </div>
                <div class="card-body d-flex flex-column">
                    <h6 class="card-title fw-bold text-truncate" title="Voucher đặt bánh kem sự kiện tại SweetDream Bakery">Voucher đặt bánh kem tại SweetDream Bakery</h6>
                    <p class="text-danger fw-bold mb-1 fs-5">500.000 đ</p>
                    <p class="text-muted small mb-3">
                        ⏳ Còn lại: <span class="fw-bold text-dark countdown-timer" data-endtime="@DateTime.Now.AddMinutes(5).AddSeconds(10).ToString("yyyy-MM-ddTHH:mm:ss")">Đang tải...</span>
                    </p>
                    <a asp-controller="Home" asp-action="Detail" class="btn btn-outline-primary w-100 mt-auto fw-bold">Ra giá ngay</a>
                </div>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const timers = document.querySelectorAll('.countdown-timer');
            function updateTimers() {
                const now = new Date().getTime();
                timers.forEach(timer => {
                    const endTimeAttr = timer.getAttribute('data-endtime');
                    if (!endTimeAttr) return;
                    const distance = new Date(endTimeAttr).getTime() - now;
                    if (distance < 0) {
                        timer.innerHTML = "<span class='text-danger'>Đã kết thúc</span>";
                        return;
                    }
                    const days = Math.floor(distance / (1000 * 60 * 60 * 24));
                    const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
                    const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
                    const seconds = Math.floor((distance % (1000 * 60)) / 1000);

                    let formattedTime = "";
                    if (days > 0) formattedTime += days + " ngày ";
                    formattedTime += String(hours).padStart(2, '0') + ":" + String(minutes).padStart(2, '0') + ":" + String(seconds).padStart(2, '0');
                    timer.innerText = formattedTime;
                });
            }
            updateTimers();
            setInterval(updateTimers, 1000);
        });
    </script>
}