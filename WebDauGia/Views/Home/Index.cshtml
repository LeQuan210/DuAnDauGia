    @model IEnumerable<WebDauGiaDomain.Entities.Product>
@{
    ViewData["Title"] = "Trang chủ";
}

<div class="container mt-4">
    <div id="heroCarousel" class="carousel slide mb-5" data-bs-ride="carousel">
        <div class="carousel-indicators">
            <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="0" class="active" aria-current="true" aria-label="Slide 1"></button>
            <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="1" aria-label="Slide 2"></button>
            <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="2" aria-label="Slide 3"></button>
        </div>
        <div class="carousel-inner rounded-4 shadow-sm">

            <div class="carousel-item active">
                <a asp-controller="Home" asp-action="ZeroPrice" class="d-block">
                    <img src="~/Picture/Banner1.jpg" class="d-block w-100" alt="Banner 1" style="object-fit: cover; height: 400px;">
                </a>
                <div class="carousel-caption d-none d-md-block bg-dark bg-opacity-50 rounded-3 p-3">
                    <h3 class="fw-bold">🔥 Tuần lễ Siêu phẩm</h3>
                    <p class="fs-5">Cơ hội sở hữu những món đồ độc lạ với giá khởi điểm từ 0 đồng.</p>
                    <button class="btn btn-warning fw-bold px-4">Tham gia ngay</button>
                </div>
            </div>

            <div class="carousel-item">
                <a asp-controller="Home" asp-action="Explore" asp-route-categoryId="4" class="d-block">
                    <img src="~/Picture/Banner2.jpg" class="d-block w-100" alt="Banner 2" style="object-fit: cover; height: 400px;">
                </a>
                <div class="carousel-caption d-none d-md-block bg-dark bg-opacity-50 rounded-3 p-3">
                    <h3 class="fw-bold">⌚ Bộ sưu tập Đồng hồ Thụy Sỹ</h3>
                    <p class="fs-5">Cam kết chính hãng. Đấu giá minh bạch.</p>
                </div>
            </div>

            <div class="carousel-item">
                <a asp-controller="Home" asp-action="Explore" asp-route-categoryId="1" class="d-block">
                    <img src="~/Picture/Banner3.jpg" class="d-block w-100" alt="Banner 3" style="object-fit: cover; height: 400px;">
                </a>
                <div class="carousel-caption d-none d-md-block bg-dark bg-opacity-50 rounded-3 p-3">
                    <h3 class="fw-bold">💻 Săn đồ Công nghệ giá hời</h3>
                    <p class="fs-5">Laptop, điện thoại, linh kiện máy tính giảm giá sập sàn.</p>
                </div>
            </div>

        </div>
        <button class="carousel-control-prev" type="button" data-bs-target="#heroCarousel" data-bs-slide="prev">
            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Trước</span>
        </button>
        <button class="carousel-control-next" type="button" data-bs-target="#heroCarousel" data-bs-slide="next">
            <span class="carousel-control-next-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Sau</span>
        </button>
    </div>
    @if (ViewBag.ExecutionTime != null)
    {
        <div class="alert alert-info border-0 shadow-sm d-flex align-items-center rounded-4" role="alert">
            <div class="bg-primary text-white rounded-circle p-2 me-3 d-flex align-items-center justify-content-center" style="width: 45px; height: 45px;">
                <i class="bi bi-cpu-fill fs-5"></i>
            </div>
            <div>
                <h6 class="mb-0 fw-bold text-primary">Xác thực Kiến trúc Onion (Layer Verification)</h6>
                <small class="text-muted">
                    @ViewBag.Message - Thời gian phản hồi:
                    <span class="badge bg-danger rounded-pill px-3">@ViewBag.ExecutionTime ms</span>
                </small>
            </div>
        </div>
    }
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-bold text-uppercase border-start border-primary border-4 ps-2">🔥 Đang đấu giá sôi nổi</h4>
        <a href="#" class="text-decoration-none text-primary fw-bold">Xem tất cả ❯</a>
    </div>

    <div class="row row-cols-1 row-cols-md-4 g-4">
        @foreach (var item in Model)
        {
            <partial name="_ProductCard" model="item" />
        }
    </div>
</div>
@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {

            // ==========================================
            // 1. XỬ LÝ ĐỒNG HỒ ĐẾM NGƯỢC NHIỀU SẢN PHẨM
            // ==========================================
            const timers = document.querySelectorAll('.countdown-timer');

            timers.forEach(function(timerElement) {
                const endTimeAttr = timerElement.getAttribute('data-endtime');
                const endTime = new Date(endTimeAttr).getTime();

                const interval = setInterval(function () {
                    const now = new Date().getTime();
                    const distance = endTime - now;

                    if (distance < 0) {
                        clearInterval(interval);
                        // Khi hết giờ thì đổi thành "Đã kết thúc" và đổi màu nền thành xám
                        timerElement.innerHTML = "Đã kết thúc";
                        timerElement.classList.replace('bg-danger', 'bg-secondary');
                        return;
                    }

                    const days = Math.floor(distance / (1000 * 60 * 60 * 24));
                    const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
                    const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
                    const seconds = Math.floor((distance % (1000 * 60)) / 1000);

                    let timeStr = "";
                    if (days > 0) timeStr += days + "d ";
                    timerElement.innerHTML = timeStr + hours + "h " + minutes + "m " + seconds + "s";
                }, 1000);
            });

            // ==========================================
            // 2. XỬ LÝ NÚT YÊU THÍCH (TRÁI TIM) BẰNG AJAX
            // ==========================================
            const favButtons = document.querySelectorAll('.btn-favorite');

            favButtons.forEach(btn => {
                btn.addEventListener('click', function(e) {
                    e.preventDefault(); // Chặn hành vi nhảy trang mặc định

                    const productId = this.getAttribute('data-id');
                    const icon = this.querySelector('i');

                    // Gọi ngầm lên Controller để lưu vào DB
                    fetch('/User/ToggleFavorite', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/x-www-form-urlencoded',
                        },
                        body: 'productId=' + productId
                    })
                    .then(response => response.json())
                    .then(data => {
                        if (data.needsLogin) {
                            alert("Anh cần đăng nhập để lưu sản phẩm yêu thích nhé!");
                            window.location.href = '/User/Login';
                            return;
                        }

                        if (data.success) {
                            // Đổi icon nếu thành công
                            if (data.isFavorite) {
                                icon.classList.remove('bi-heart', 'text-secondary');
                                icon.classList.add('bi-heart-fill', 'text-danger'); // Tim đỏ
                            } else {
                                icon.classList.remove('bi-heart-fill', 'text-danger');
                                icon.classList.add('bi-heart', 'text-secondary'); // Tim rỗng
                            }
                        }
                    })
                    .catch(err => console.error("Lỗi:", err));
                });
            });
        });
    </script>
}