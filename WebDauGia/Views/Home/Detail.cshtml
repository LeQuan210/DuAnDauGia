@model WebDauGiaDomain.Entities.Product
@{
    ViewData["Title"] = "Phòng Đấu Giá";
}



<div class="container my-4">
    <div class="row g-4">
        <div class="col-lg-7">
            <div class="card shadow-sm border-0 mb-3 rounded-4 overflow-hidden">
                <div class="bg-light text-center d-flex align-items-center justify-content-center" style="height: 450px;">
                    <img src="@(string.IsNullOrEmpty(Model.ImageUrl) ? "/picture/default-product.jpg" : Model.ImageUrl)" class="img-fluid w-100 h-100" alt="@Model.Name" style="object-fit: cover;">
                </div>
            </div>

            <div class="card shadow-sm border-0 mb-3 rounded-4">
                <div class="card-header bg-white border-bottom fw-bold fs-5 py-3">
                    @Model.Name
                </div>
                <div class="card-body">
                    <div class="text-muted mb-0" style="line-height: 1.8;">
                        @Model.Description
                    </div>
                </div>
            </div>

            <div class="row g-3">
                <div class="col-md-5">
                    <div class="card shadow-sm border-0 bg-light h-100 rounded-4">
                        <div class="card-body text-center d-flex flex-column justify-content-center">
                            <p class="text-muted mb-1 fs-6">Giá khởi điểm</p>
                            <h4 class="fw-bold text-dark mb-0">@Model.StartPrice.ToString("N0") đ</h4>
                        </div>
                    </div>
                </div>
                <div class="col-md-7">
                    <div class="card shadow-sm border-0 border-primary border-2 h-100 rounded-4 bg-primary bg-opacity-10">
                        <div class="card-body text-center d-flex flex-column justify-content-center">
                            <p class="text-primary fw-bold mb-1 fs-6">Giá hiện tại</p>
                            <h3 class="fw-bold text-danger mb-0" id="currentPrice">@Model.CurrentPrice.ToString("N0") đ</h3>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-5 d-flex flex-column">
            <div class="card shadow-sm border-0 flex-grow-1 d-flex flex-column rounded-4 overflow-hidden">

                <div class="card-header bg-white border-bottom d-flex justify-content-between align-items-center p-3">
                    <span class="fw-bold fs-5"><i class="bi bi-activity me-2 text-primary"></i>Diễn biến</span>
                    <span class="badge bg-danger fs-6 px-3 py-2 rounded-pill shadow-sm d-flex align-items-center">
                        <i class="bi bi-hourglass-split me-1"></i>
                        <span class="countdown-timer" data-endtime="@Model.AuctionEndTime.ToString("yyyy-MM-ddTHH:mm:ss")">Đang tính...</span>
                    </span>
                </div>

                @if (User.Identity.IsAuthenticated){
                    <div class="bg-warning bg-opacity-10 border-bottom border-warning p-3 shadow-sm">
                        <p class="fw-bold text-warning mb-2 text-uppercase" style="font-size: 0.85rem;"><i class="bi bi-star-fill me-1"></i> Quyền quản lý phiên</p>
                        <div class="d-flex gap-2">
                            <button class="btn btn-outline-danger w-50 fw-bold" onclick="if(confirm('Anh có chắc chắn muốn hủy phiên đấu giá này không? Mọi lịch sử đặt giá sẽ bị xóa bỏ.')) { alert('Đã hủy phiên đấu giá thành công!'); window.location.href='/Home/Index'; }">
                                <i class="bi bi-x-circle me-1"></i>Hủy đấu giá
                            </button>
                            <button class="btn btn-success w-50 fw-bold shadow-sm" onclick="window.ketThucPhien(true)">
                                <i class="bi bi-hammer me-1"></i>Chốt ngay
                            </button>
                        </div>
                    </div>
                }

                <div class="card-body bg-light overflow-auto p-3" id="chatBox" style="height: 480px; max-height: 480px;">
                    <div class="text-center text-muted small py-3">
                        <i class="bi bi-info-circle me-1"></i> Lịch sử trả giá sẽ xuất hiện tại đây...
                    </div>
                </div>

                <div class="card-footer bg-white border-top p-3" id="bidFooter">
                    <div class="input-group input-group-lg shadow-sm rounded-3 overflow-hidden">
                        <input type="number" class="form-control fs-6 border-0 bg-light" id="bidInput" placeholder="Nhập số tiền..." min="5000" step="1000">
                        <button class="btn btn-primary fw-bold px-4" type="button" id="btnPlaceBid">ĐẶT GIÁ</button>
                    </div>
                    <small class="text-muted mt-2 d-block text-center"><i class="bi bi-info-circle me-1"></i>Bước giá tối thiểu: 5.000 VNĐ</small>
                </div>
            </div>
        </div>
    </div>
</div>

<div id="winnerOverlay" class="position-fixed top-0 start-0 w-100 h-100 bg-dark bg-opacity-75 d-none justify-content-center align-items-center" style="z-index: 9999; backdrop-filter: blur(5px);">
    <div class="bg-white p-5 rounded-4 shadow-lg text-center mx-3" style="max-width: 500px; animation: popIn 0.5s ease-out;">
        <div class="text-warning mb-3" style="font-size: 4rem; line-height: 1;"><i class="bi bi-trophy-fill"></i></div>
        <h2 class="fw-bold text-dark mb-4">Phiên đấu giá đã kết thúc!</h2>
        <div class="bg-light rounded-3 p-3 mb-4 border">
            <p class="fs-6 text-muted mb-1">Người thắng cuộc</p>
            <p class="fs-4 fw-bold text-primary mb-3" id="winnerNameDisplay">Đang xác định...</p>
            <hr class="w-50 mx-auto my-2">
            <p class="fs-6 text-muted mb-1 mt-3">Mức giá chốt</p>
            <p class="text-danger fw-bold fs-3 mb-0" id="finalPriceDisplay">0 đ</p>
        </div>

        <a href="#" id="btnCheckout" class="btn btn-primary w-100 fw-bold py-3 fs-5 rounded-pill shadow-sm">
            <i class="bi bi-credit-card me-2"></i>Thanh toán ngay
        </a>
        <a asp-controller="Home" asp-action="Index" class="btn btn-light w-100 fw-bold py-2 mt-2 rounded-pill">Về trang chủ</a>
    </div>
</div>
@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>

    <script>
        // --- KHAI BÁO BIẾN TOÀN CỤC (Để ở ngoài cùng cho chắc) ---
        let lastBidder = "Chưa có người đặt";
        let lastPrice = parseInt("@Model.StartPrice");
        let botIntervalId = null;
        let countdownIntervalId = null;

        document.addEventListener('DOMContentLoaded', function () {
            const productId = "@Model.Id";
            const currentUser = "@(User.Identity.IsAuthenticated? User.Identity.Name : "")";
            const startPrice = parseInt("@Model.StartPrice");

            // --- HÀM CHỐT PHIÊN (XỬ LÝ TRIỆT ĐỂ LỖI 0 Đ) ---
            window.ketThucPhien = function(isManual) {
                if (isManual && !confirm('Anh có chắc muốn chốt ngay mức giá này không?')) return;

                // 1. Dừng ngay lập tức Bot và Đồng hồ
                if (botIntervalId) clearInterval(botIntervalId);
                if (countdownIntervalId) clearInterval(countdownIntervalId);

                // 2. Khóa nút đặt giá
                const btnBid = document.getElementById("btnPlaceBid");
                if (btnBid) btnBid.disabled = true;

                // 3. ÉP DỮ LIỆU VÀO POPUP (Dùng biến lastBidder và lastPrice vừa cập nhật)
                document.getElementById('winnerNameDisplay').innerText = lastBidder;
                document.getElementById('finalPriceDisplay').innerText = new Intl.NumberFormat('vi-VN').format(lastPrice) + " đ";

                // 4. GÁN LINK THANH TOÁN (Ép link trực tiếp)
                const payLink = `/User/Checkout?productId=${productId}&amount=${lastPrice}`;
                document.getElementById('btnCheckout').setAttribute('href', payLink);

                // 5. HIỆN POPUP
                document.getElementById('winnerOverlay').classList.remove('d-none');
                document.getElementById('winnerOverlay').classList.add('d-flex');
            };

            // --- ĐỒNG HỒ ĐẾM NGƯỢC ---
            const timerElement = document.querySelector('.countdown-timer');
            if (timerElement) {
                const endTime = new Date(timerElement.getAttribute('data-endtime')).getTime();
                countdownIntervalId = setInterval(function () {
                    const distance = endTime - new Date().getTime();
                    if (distance < 0) {
                        clearInterval(countdownIntervalId);
                        timerElement.innerHTML = "Đã kết thúc";
                        window.ketThucPhien(false); // Hết giờ tự chốt
                        return;
                    }
                    const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
                    const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
                    const seconds = Math.floor((distance % (1000 * 60)) / 1000);
                    timerElement.innerHTML = hours + "h " + minutes + "m " + seconds + "s";
                }, 1000);
            }

            // --- SIGNALR & BOT ---
            try {
                const connection = new signalR.HubConnectionBuilder().withUrl("/auctionHub").build();

                connection.on("ReceiveBid", function (user, amount) {
                    // CẬP NHẬT BIẾN TOÀN CỤC NGAY KHI CÓ GIÁ MỚI
                    lastBidder = user;
                    lastPrice = parseInt(amount);

                    // Cập nhật giá trên màn hình chính
                    document.getElementById("currentPrice").innerText = new Intl.NumberFormat('vi-VN').format(amount) + " đ";

                    const chatBox = document.getElementById("chatBox");
                    if (chatBox) {
                        const isMe = user === currentUser;
                        const div = document.createElement("div");
                        div.className = "d-flex mb-3 " + (isMe ? "justify-content-end" : "justify-content-start");
                        div.innerHTML = `<div class="p-2 rounded-4 shadow-sm ${isMe ? 'bg-primary text-white' : 'bg-white border'}" style="max-width: 80%">
                            <small class="fw-bold d-block">${isMe ? 'Bạn' : user}</small>
                            <span>Đã đặt: <strong>${new Intl.NumberFormat('vi-VN').format(amount)} đ</strong></span>
                        </div>`;
                        chatBox.appendChild(div);
                        chatBox.scrollTop = chatBox.scrollHeight;
                    }
                });

                connection.start().then(function () {
                    connection.invoke("JoinProductGroup", productId);

                    // BOT TỰ ĐỘNG (Dừng lại ngay khi lastBidder thay đổi hoặc chốt phiên)
                    botIntervalId = setInterval(() => {
                        const botNames = ["[Bot] Đại gia giấu mặt", "[Bot] Dân chơi xóm"];
                        const randomBot = botNames[Math.floor(Math.random() * botNames.length)];
                        const newTotal = lastPrice + 10000; // Bot luôn cộng thêm 10k
                        connection.invoke("SendBid", productId, randomBot, newTotal);
                    }, 15000); // 15 giây bot nhảy 1 lần cho thong thả

                }).catch(err => console.error(err));

                // NÚT ĐẶT GIÁ CỦA ANH
                document.getElementById("btnPlaceBid").addEventListener('click', function (e) {
                    const bidStep = parseInt(document.getElementById("bidInput").value);
                    if (isNaN(bidStep) || bidStep < 5000) return alert("Nhập tối thiểu 5.000đ");

                    const totalAmount = lastPrice + bidStep;
                    // Bắn giá lên Hub
                    connection.invoke("SendBid", productId, currentUser, totalAmount);
                    document.getElementById("bidInput").value = '';
                });

            } catch (e) { console.error(e); }
        });
    </script>
}
<style>
        @@keyframes popIn {
            0%

        {
            opacity: 0;
            transform: scale(0.95) translateY(10px);
        }

        100% {
            opacity: 1;
            transform: scale(1) translateY(0);
        }

        }

        #chatBox::-webkit-scrollbar {
            width: 6px;
        }

        #chatBox::-webkit-scrollbar-track {
            background: #f1f1f1;
        }

        #chatBox::-webkit-scrollbar-thumb {
            background: #ccc;
            border-radius: 10px;
        }

            #chatBox::-webkit-scrollbar-thumb:hover {
                background: #888;
            }
    </style>
