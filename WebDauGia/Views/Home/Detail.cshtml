@model WebDauGiaDomain.Entities.Product
@{
    ViewData["Title"] = "Phòng Đấu Giá";
}



<div class="container my-4">
    <div class="row g-4">
        <div class="col-lg-7">
            <div class="card shadow-sm border-0 mb-3 rounded-4 overflow-hidden">
                <div class="bg-light text-center d-flex align-items-center justify-content-center" style="height: 450px;">
                    <img src="@(string.IsNullOrEmpty(Model.ImageUrl) ? "/picture/default-product.jpg" : Model.ImageUrl)" class="img-fluid w-100 h-100" alt="@Model.Name" style="object-fit: cover;">
                </div>
            </div>

            <div class="card shadow-sm border-0 mb-3 rounded-4">
                <div class="card-header bg-white border-bottom fw-bold fs-5 py-3">
                    @Model.Name
                </div>
                <div class="card-body">
                    <div class="text-muted mb-0" style="line-height: 1.8;">
                        @Html.Raw(Model.Description)
                    </div>
                </div>
            </div>

            <div class="row g-3">
                <div class="col-md-5">
                    <div class="card shadow-sm border-0 bg-light h-100 rounded-4">
                        <div class="card-body text-center d-flex flex-column justify-content-center">
                            <p class="text-muted mb-1 fs-6">Giá khởi điểm</p>
                            <h4 class="fw-bold text-dark mb-0">@Model.StartPrice.ToString("N0") đ</h4>
                        </div>
                    </div>
                </div>
                <div class="col-md-7">
                    <div class="card shadow-sm border-0 border-primary border-2 h-100 rounded-4 bg-primary bg-opacity-10">
                        <div class="card-body text-center d-flex flex-column justify-content-center">
                            <p class="text-primary fw-bold mb-1 fs-6">Giá hiện tại</p>
                            <h3 class="fw-bold text-danger mb-0" id="currentPrice">@Model.CurrentPrice.ToString("N0") đ</h3>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-5 d-flex flex-column">
            <div class="card shadow-sm border-0 flex-grow-1 d-flex flex-column rounded-4 overflow-hidden">

                <div class="card-header bg-white border-bottom d-flex justify-content-between align-items-center p-3">
                    <span class="fw-bold fs-5"><i class="bi bi-activity me-2 text-primary"></i>Diễn biến</span>
                    <span class="badge bg-danger fs-6 px-3 py-2 rounded-pill shadow-sm d-flex align-items-center">
                        <i class="bi bi-hourglass-split me-1"></i>
                        <span class="countdown-timer" data-endtime="@Model.AuctionEndTime.ToString("yyyy-MM-ddTHH:mm:ss")">Đang tính...</span>
                    </span>
                </div>

                @if (ViewBag.IsSeller != null && ViewBag.IsSeller == true)
                {
                    <div class="bg-warning bg-opacity-10 border-bottom border-warning p-3 shadow-sm">
                        <p class="fw-bold text-warning mb-2 text-uppercase" style="font-size: 0.85rem;"><i class="bi bi-star-fill me-1"></i> Quyền quản lý phiên</p>
                        <div class="d-flex gap-2">
                            <button class="btn btn-outline-danger w-50 fw-bold" onclick="if(confirm('Anh có chắc chắn muốn hủy phiên đấu giá này không? Mọi lịch sử đặt giá sẽ bị xóa bỏ.')) { alert('Đã hủy phiên đấu giá thành công!'); window.location.href='/Home/Index'; }">
                                <i class="bi bi-x-circle me-1"></i>Hủy đấu giá
                            </button>
                            <button class="btn btn-success w-50 fw-bold shadow-sm" onclick="if(confirm('Anh muốn chốt ngay mức giá cao nhất hiện tại cho người này?')) { alert('Chốt phiên thành công!'); document.getElementById('winnerOverlay').classList.remove('d-none'); document.getElementById('winnerOverlay').classList.add('d-flex'); }">
                                <i class="bi bi-hammer me-1"></i>Chốt ngay
                            </button>
                        </div>
                    </div>
                }

                <div class="card-body bg-light overflow-auto p-3" id="chatBox" style="height: 480px; max-height: 480px;">
                    <div class="text-center text-muted small py-3">
                        <i class="bi bi-info-circle me-1"></i> Lịch sử trả giá sẽ xuất hiện tại đây...
                    </div>
                </div>

                <div class="card-footer bg-white border-top p-3" id="bidFooter">
                    <div class="input-group input-group-lg shadow-sm rounded-3 overflow-hidden">
                        <input type="number" class="form-control fs-6 border-0 bg-light" id="bidInput" placeholder="Nhập số tiền..." min="5000" step="1000">
                        <button class="btn btn-primary fw-bold px-4" type="button" id="btnPlaceBid">ĐẶT GIÁ</button>
                    </div>
                    <small class="text-muted mt-2 d-block text-center"><i class="bi bi-info-circle me-1"></i>Bước giá tối thiểu: 5.000 VNĐ</small>
                </div>
            </div>
        </div>
    </div>
</div>

<div id="winnerOverlay" class="position-fixed top-0 start-0 w-100 h-100 bg-dark bg-opacity-75 d-none justify-content-center align-items-center" style="z-index: 9999; backdrop-filter: blur(5px);">
    <div class="bg-white p-5 rounded-4 shadow-lg text-center mx-3" style="max-width: 500px; animation: popIn 0.5s ease-out;">
        <div class="text-warning mb-3" style="font-size: 4rem; line-height: 1;"><i class="bi bi-trophy-fill"></i></div>
        <h2 class="fw-bold text-dark mb-4">Phiên đấu giá đã kết thúc!</h2>
        <div class="bg-light rounded-3 p-3 mb-4 border">
            <p class="fs-6 text-muted mb-1">Người thắng cuộc</p>
            <p class="fs-4 fw-bold text-primary mb-3">@User.Identity.Name</p>
            <hr class="w-50 mx-auto my-2">
            <p class="fs-6 text-muted mb-1 mt-3">Mức giá chốt</p>
            <p class="text-danger fw-bold fs-3 mb-0" id="finalPriceDisplay"></p>
        </div>

        <a asp-controller="Home" asp-action="Index" class="btn btn-primary w-100 fw-bold py-3 fs-5 rounded-pill">Đóng & Về trang chủ</a>
    </div>
</div>

@section Scripts {
    <script src="~/lib/microsoft/signalr/dist/browser/signalr.js"></script>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // 1. Lấy thông tin cơ bản
            const productId = "@Model.Id";
            const currentUser = "@(User.Identity.IsAuthenticated? User.Identity.Name : "")";

            // 2. Kết nối tới đài phát thanh (Hub)
            const connection = new signalR.HubConnectionBuilder()
                .withUrl("/auctionHub")
                .build();

            // 3. Lắng nghe khi có người đặt giá thành công
            connection.on("ReceiveBid", function (user, amount) {
                document.getElementById("currentPrice").innerText = new Intl.NumberFormat('vi-VN').format(amount) + " đ";

                const chatBox = document.getElementById("chatBox");
                const isMe = user === currentUser;

                const div = document.createElement("div");
                div.className = "d-flex mb-3 " + (isMe ? "justify-content-end" : "");

                const innerDiv = document.createElement("div");
                innerDiv.className = isMe
                    ? "bg-primary bg-opacity-10 border border-primary rounded-4 p-2 shadow-sm text-end"
                    : "bg-white border rounded-4 p-2 shadow-sm";
                innerDiv.style.maxWidth = "85%";

                innerDiv.innerHTML = `
                    <small class="fw-bold ${isMe ? 'text-primary pe-1' : 'text-secondary ps-1'} d-block">${isMe ? 'Bạn' : user}</small>
                    <span class="text-dark px-1">Đã đặt <strong class="text-danger">${new Intl.NumberFormat('vi-VN').format(amount)} VNĐ</strong></span>
                `;

                div.appendChild(innerDiv);
                chatBox.appendChild(div);
                chatBox.scrollTop = chatBox.scrollHeight;
            });

            // Khởi động kết nối
            connection.start().then(function () {
                connection.invoke("JoinProductGroup", productId);
                const chatBox = document.getElementById("chatBox");
                if (chatBox) chatBox.innerHTML = '';
            }).catch(function (err) {
                return console.error(err.toString());
            });

            // 4. Xử lý nút ĐẶT GIÁ và đo thời gian AJAX ngầm
            const btnBid = document.getElementById("btnPlaceBid");
            if (btnBid) {
                btnBid.addEventListener('click', function (e) {
                    e.preventDefault();

                    if (!currentUser) {
                        window.location.href = '/User/Login?ReturnUrl=' + window.location.pathname;
                        return;
                    }

                    const inputBid = document.getElementById("bidInput");
                    const bidAmount = parseInt(inputBid.value);

                    if (isNaN(bidAmount) || bidAmount < 5000) {
                        alert("Anh nhập số tiền hợp lệ (từ 5.000 VNĐ) nhé!");
                        return;
                    }

                    btnBid.disabled = true;
                    btnBid.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Đang xử lý...';

                    fetch('/User/ValidateBidBalance', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/x-www-form-urlencoded',
                        },
                        body: 'bidAmount=' + bidAmount
                    })
                    .then(response => response.json())
                    .then(data => {
                        if (data.needsLogin) {
                            window.location.href = '/User/Login?ReturnUrl=' + window.location.pathname;
                            return;
                        }
                        if (data.success) {
                            // --- IN RA CONSOLE F12 CHO THẦY CHẤM ĐIỂM ---
                            console.log("%c[Onion Architecture] Tác vụ AJAX ngầm thành công!", "color: #0d6efd; font-weight: bold;");
                            console.log("%c⏱ Thời gian Server xử lý: " + data.time + " ms", "color: #dc3545; font-size: 14px; font-weight: bold;");

                            // --- HIỆN THÔNG BÁO XANH LÁ TRÊN MÀN HÌNH ---
                            let timeLog = document.getElementById("ajaxTimeLog");
                            if (!timeLog) {
                                timeLog = document.createElement("div");
                                timeLog.id = "ajaxTimeLog";
                                timeLog.className = "alert alert-success py-1 px-2 mt-2 mb-0 text-center animate__animated animate__fadeIn";
                                timeLog.style.fontSize = "0.85rem";
                                document.getElementById("bidFooter").appendChild(timeLog);
                            }
                            timeLog.innerHTML = `<i class="bi bi-stopwatch me-1"></i> Xác thực luồng ngầm: <strong>${data.time} ms</strong>`;

                            setTimeout(() => { if (timeLog) timeLog.remove(); }, 3000);

                            // Phóng dữ liệu lên SignalR
                            connection.invoke("SendBid", productId, currentUser, bidAmount).catch(function (err) {
                                console.error(err.toString());
                            });
                            inputBid.value = '';
                        } else {
                            if (confirm(data.message + '\nAnh có muốn sang trang Nạp tiền ngay bây giờ không?')) {
                                window.location.href = '/User/Deposit';
                            }
                        }
                    })
                    .catch(error => {
                        console.error('Error:', error);
                        alert('Có lỗi hệ thống khi kiểm tra số dư.');
                    })
                    .finally(() => {
                        btnBid.disabled = false;
                        btnBid.innerHTML = 'ĐẶT GIÁ';
                    });
                });
            }
        });
    </script>
}
<style>
        @@keyframes popIn {
            0%

        {
            opacity: 0;
            transform: scale(0.95) translateY(10px);
        }

        100% {
            opacity: 1;
            transform: scale(1) translateY(0);
        }

        }

        #chatBox::-webkit-scrollbar {
            width: 6px;
        }

        #chatBox::-webkit-scrollbar-track {
            background: #f1f1f1;
        }

        #chatBox::-webkit-scrollbar-thumb {
            background: #ccc;
            border-radius: 10px;
        }

            #chatBox::-webkit-scrollbar-thumb:hover {
                background: #888;
            }
    </style>
