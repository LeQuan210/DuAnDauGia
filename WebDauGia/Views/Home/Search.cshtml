@{
    ViewData["Title"] = "Kết quả tìm kiếm";
}
<div class="container my-5">
    <h4 class="fw-bold mb-4">Kết quả tìm kiếm cho: <span class="text-primary">"@ViewBag.Query"</span></h4>
    <p class="text-muted">Tìm thấy 12 sản phẩm phù hợp.</p>

    <div class="row row-cols-1 row-cols-md-4 g-4 mb-5">
        <div class="col">
            <div class="card h-100 shadow-sm border-0 rounded-3">
                <div class="position-relative">
                    <div class="bg-light text-muted d-flex align-items-center justify-content-center rounded-top" style="height: 200px;">Ảnh @ViewBag.Query</div>
                    <span class="badge bg-danger position-absolute top-0 end-0 m-2">Đang đấu giá</span>
                </div>
                <div class="card-body">
                    <h6 class="fw-bold text-truncate">@ViewBag.Query (Phiên bản giới hạn)</h6>
                    <p class="text-danger fw-bold fs-5 mb-2">2.500.000 đ</p>
                    <a asp-controller="Home" asp-action="Detail" class="btn btn-outline-primary w-100 fw-bold">Xem chi tiết</a>
                </div>
            </div>
        </div>
    </div>
</div>