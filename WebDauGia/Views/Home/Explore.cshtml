@model IEnumerable<WebDauGiaDomain.Entities.Product>
@{
    ViewData["Title"] = "Danh mục sản phẩm";
}
<div class="container my-5">
    <h4 class="fw-bold mb-4 border-bottom pb-2">
        Danh mục: <span class="text-success">@ViewBag.CategoryName</span>
    </h4>

    @if (!Model.Any())
    {
        <div class="text-center py-5 text-muted">
            <i class="bi bi-box-seam" style="font-size: 3rem;"></i>
            <p class="mt-3 fs-5">Hiện tại danh mục này chưa có sản phẩm nào đang đấu giá.</p>
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4">
            @foreach (var item in Model)
            {
                <partial name="_ProductCard" model="item" />
            }
        </div>
    }
</div>