@{
    ViewData["Title"] = ViewBag.CategoryTitle;
}

<div class="container my-4">
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
        <h3 class="fw-bold text-primary text-uppercase mb-0">@ViewBag.CategoryTitle</h3>

        <div class="d-flex align-items-center">
            <span class="text-muted me-2 text-nowrap">Sắp xếp theo:</span>
            <select class="form-select border-primary fw-bold" style="width: 200px;">
                <option value="time_asc">Thời gian kết thúc gần nhất</option>
                <option value="newest">Mới cập nhật</option>
                <option value="price_asc">Giá tăng dần</option>
                <option value="price_desc">Giá giảm dần</option>
            </select>
        </div>
    </div>

    @if (ViewBag.Category != "ending")
    {
        <h5 class="fw-bold text-dark mb-3"><i class="bi bi-clock-history me-2 text-warning"></i>Phiên Sắp Mở</h5>
        <div class="row row-cols-1 row-cols-md-4 g-4 mb-5">
            <div class="col">
                <div class="card h-100 shadow-sm border-0 rounded-3">
                    <div class="position-relative">
                        <div class="bg-secondary text-white d-flex align-items-center justify-content-center rounded-top" style="height: 200px;">Ảnh Sản Phẩm</div>
                        <span class="badge bg-secondary position-absolute top-0 end-0 m-2">Chưa bắt đầu</span>
                    </div>
                    <div class="card-body">
                        <h6 class="fw-bold text-truncate">iPhone 15 Pro Max 256GB</h6>
                        <p class="text-muted mb-1">Giá khởi điểm:</p>
                        <p class="text-dark fw-bold fs-5">20.000.000 đ</p>
                        <button class="btn btn-light w-100 mt-2" disabled>Mở sau: 2 ngày nữa</button>
                    </div>
                </div>
            </div>
        </div>
    }

    <h5 class="fw-bold text-dark mb-3"><i class="bi bi-fire me-2 text-danger"></i>Đang Diễn Ra</h5>
    <div class="row row-cols-1 row-cols-md-4 g-4 mb-5">
        <div class="col">
            <div class="card h-100 shadow-sm border-0 rounded-3 border-primary border-2">
                <div class="position-relative">
                    <div class="bg-primary text-white d-flex align-items-center justify-content-center rounded-top" style="height: 200px; opacity: 0.8;">Ảnh Sản Phẩm</div>
                    <span class="badge bg-danger position-absolute top-0 end-0 m-2">Đang đấu giá</span>
                </div>
                <div class="card-body">
                    <h6 class="fw-bold text-truncate">Macbook Air M2 8GB/256GB</h6>
                    <p class="text-muted mb-1">Giá hiện tại:</p>
                    <p class="text-danger fw-bold fs-5">15.500.000 đ</p>

                    @if (ViewBag.Category == "ending")
                    {
                        <p class="small text-muted mb-2">⏳ Còn lại: <span class="fw-bold text-danger countdown-timer" data-endtime="@DateTime.Now.AddMinutes(45).ToString("yyyy-MM-ddTHH:mm:ss")">Đang tải...</span></p>
                    }
                    else
                    {
                        <p class="small text-muted mb-2">⏳ Còn lại: <span class="fw-bold text-dark countdown-timer" data-endtime="@DateTime.Now.AddHours(5).ToString("yyyy-MM-ddTHH:mm:ss")">Đang tải...</span></p>
                    }
                    <a asp-controller="Home" asp-action="Detail" class="btn btn-outline-primary w-100 mt-auto fw-bold">Ra giá ngay</a>
                </div>
            </div>
        </div>
    </div>

    <h5 class="fw-bold text-muted mb-3"><i class="bi bi-check-circle-fill me-2 text-success"></i>Đã Kết Thúc</h5>
    <div class="row row-cols-1 row-cols-md-4 g-4 mb-5 opacity-75">
        <div class="col">
            <div class="card h-100 shadow-sm border-0 rounded-3 bg-light">
                <div class="position-relative">
                    <div class="bg-dark text-white d-flex align-items-center justify-content-center rounded-top" style="height: 200px;">Ảnh Sản Phẩm</div>
                    <span class="badge bg-dark position-absolute top-0 end-0 m-2">Đã đóng</span>
                </div>
                <div class="card-body">
                    <h6 class="fw-bold text-truncate">Tai nghe AirPods Pro 2</h6>
                    <p class="text-muted mb-1">Giá chốt cuối cùng:</p>
                    <p class="text-success fw-bold fs-5">4.200.000 đ</p>
                    <button class="btn btn-secondary w-100 mt-2" disabled>Người thắng: a***9</button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const timers = document.querySelectorAll('.countdown-timer');
            function updateTimers() {
                const now = new Date().getTime();
                timers.forEach(timer => {
                    const endTimeAttr = timer.getAttribute('data-endtime');
                    if (!endTimeAttr) return;
                    const distance = new Date(endTimeAttr).getTime() - now;
                    if (distance < 0) {
                        timer.innerHTML = "<span class='text-danger'>Đã kết thúc</span>";
                        return;
                    }
                    const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
                    const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
                    const seconds = Math.floor((distance % (1000 * 60)) / 1000);
                    timer.innerText = String(hours).padStart(2, '0') + ":" + String(minutes).padStart(2, '0') + ":" + String(seconds).padStart(2, '0');
                });
            }
            updateTimers();
            setInterval(updateTimers, 1000);
        });
    </script>
}