@model IEnumerable<WebDauGiaDomain.Entities.SystemLog>
@{
    ViewData["Title"] = "Nhật ký hệ thống";
}

<div class="container my-5">
    <h3 class="fw-bold mb-4"><i class="bi bi-camera-video me-2 text-danger"></i>Camera Giám Sát (System Logs)</h3>

    <div class="card shadow-sm border-0 rounded-3 overflow-hidden">
        <table class="table table-striped table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th width="15%">Thời gian</th>
                    <th width="15%">Người thao tác (ID)</th>
                    <th width="50%">Hành động</th>
                    <th width="20%">Địa chỉ IP</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var log in Model)
                {
                    <tr>
                        <td class="text-muted small">@log.Timestamp.ToString("dd/MM/yyyy HH:mm:ss")</td>
                        <td class="fw-bold">@(log.UserId.HasValue ? $"User #{log.UserId}" : "Hệ thống/Khách")</td>
                        <td>@log.Action</td>
                        <td><span class="badge bg-secondary">@log.IPAddress</span></td>
                    </tr>
                }
            </tbody>
        </table>
        @if (!Model.Any())
        {
            <div class="text-center py-4 text-muted">Chưa có bản ghi nhật ký nào.</div>
        }
    </div>
</div>